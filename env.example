# Deployer's private key (NEVER commit the real value to Git)
PRIVATE_KEY=0x...

# Deployer's address
DEPLOYER=0x...

# RPC endpoint for the network you are deploying to
RPC_URL=https://ethereum-rpc.publicnode.com

# Chain ID of the target network (used as a deploy-time safety check)
CHAIN_ID=1

# Block explorer API key (Etherscan-compatible) used for contract verification
ETHERSCAN_API_KEY=

# Optional: explicit verifier API URL. Leave blank when using modern Foundry +
# Etherscan v2 (the endpoint is resolved from --chain-id). Set this only if you are
# on an older Foundry or a non-Etherscan explorer, then pass it as --verifier-url.
ETHERSCAN_API_URL=

# Contract address (set after deployment)
CONTRACT_ADDRESS=
